#!/usr/bin/env bash
# versions-cpu.env — Pinned versions for PyTorch CPU AL2023 DLC
# Source this file: source versions-cpu.env

# ── Image metadata ──────────────────────────────────────────────
export DLC_MAJOR_VERSION="1"
export DLC_MINOR_VERSION="0"

# ── Python ──────────────────────────────────────────────────────
export PYTHON_VERSION="3.12"

# ── PyTorch ecosystem ──────────────────────────────────────────
export TORCH_VERSION="2.11.0"
export TORCHVISION_VERSION="0.26.0"
export TORCHAUDIO_VERSION="2.11.0"

# ── Distributed ────────────────────────────────────────────────
export OPEN_MPI_VERSION="4.1.7"
export DEEPSPEED_VERSION="0.18.8"
