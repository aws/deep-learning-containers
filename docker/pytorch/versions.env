#!/usr/bin/env bash
# versions.env — Pinned versions for PyTorch AL2023 DLC
# Source this file: source versions.env

# ── Image metadata ──────────────────────────────────────────────
export DLC_MAJOR_VERSION="1"
export DLC_MINOR_VERSION="0"
export BUILD_DATE="$(date +%Y%m%d)"

# ── CUDA / cuDNN / NCCL ────────────────────────────────────────
export CUDA_VERSION="12.9.1"
export NCCL_VERSION="2.26.2"

# ── Python ──────────────────────────────────────────────────────
export PYTHON_VERSION="3.12"

# ── PyTorch ecosystem ──────────────────────────────────────────
export TORCH_VERSION="2.10.0"
export TORCHVISION_VERSION="0.25.0"
export TORCHAUDIO_VERSION="2.10.0"

# ── Accelerator libraries ──────────────────────────────────────
export FLASH_ATTN_VERSION="2.8.3"
export DEEPSPEED_VERSION="0.16.7"
export TRANSFORMER_ENGINE_VERSION="2.3.0"

# ── Networking / distributed ───────────────────────────────────
export EFA_VERSION="1.47.0"
export GDRCOPY_VERSION="2.4.4"

# ── Build settings ─────────────────────────────────────────────
export MAX_JOBS="8"
