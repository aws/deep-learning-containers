#!/usr/bin/env bash
# versions.env — Pinned build-args for the vLLM-Omni AL2023 image.
# Source this file: source docker/vllm_omni/versions.env
#
# These override the Dockerfile ARG defaults at build time so the omni image
# is not affected by unrelated Dockerfile edits. Every var exported here is
# auto-forwarded as --build-arg to docker buildx by the workflow.
#
# Do NOT re-export vars the workflow already passes (CUDA_VERSION,
# PYTHON_VERSION, USE_SCCACHE, USE_PREBUILT_WHEEL, etc.).

# ── vLLM source & version ──────────────────────────────────────
export VLLM_REPO="https://github.com/vllm-project/vllm.git"
export VLLM_VERSION="0.20.0"
export VLLM_REF="v${VLLM_VERSION}"
# vllm-omni v0.20.0 is still a release candidate; bump to final once published.
export VLLM_OMNI_VERSION="0.20.0rc1"

# ── Accelerator libraries ──────────────────────────────────────
export FLASHINFER_VERSION="0.6.8.post1"
export DEEPEP_COMMIT_HASH="73b6ea4"
# export NVSHMEM_VER=""   # uncomment to pin; unset = Dockerfile default

# ── Networking ─────────────────────────────────────────────────
export EFA_VERSION="1.47.0"

# ── DLC image versioning ───────────────────────────────────────
export DLC_MAJOR_VERSION="1"
export DLC_MINOR_VERSION="0"

# ── Build configuration ────────────────────────────────────────
# Aligned with upstream vllm v0.20.0 Dockerfile.
export torch_cuda_arch_list="7.5 8.0 8.6 8.9 9.0 10.0 11.0 12.0+PTX"
export INSTALL_KV_CONNECTORS="true"
