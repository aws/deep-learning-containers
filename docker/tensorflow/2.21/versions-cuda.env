# versions-cuda.env — Pinned versions for TensorFlow CUDA AL2023 DLC
# Source this file: source versions-cuda.env

# ── Image metadata ──────────────────────────────────────────────
export DLC_MAJOR_VERSION="1"
export DLC_MINOR_VERSION="0"
export BUILD_DATE="$(date +%Y%m%d)"

# ── CUDA / NCCL ────────────────────────────────────────────────
# CUDA 12.9.1 — TF 2.21 was upstream-tested against 12.5; we rely on
# CUDA minor-version forward-compat to run the 12.5-built wheel on 12.9.
# cuDNN and NCCL come from pip (nvidia-cudnn-cu12, nvidia-nccl-cu12) in
# cuda/pyproject.toml — AL2023 core and NVIDIA's amzn2023 CUDA repo don't
# ship the RPMs.
export CUDA_VERSION="12.9.1"
export NCCL_VERSION="2.29.7-1"
export NCCL_OFI_VERSION="1.19.0"  # Bundled by aws-efa-installer 1.48.0

# ── Python ──────────────────────────────────────────────────────
export PYTHON_VERSION="3.12"

# ── TensorFlow ─────────────────────────────────────────────────
# Wheel resolves from PyPI via cuda/pyproject.toml + cuda/uv.lock.
# TF_VERSION below is informational — used for label/tag generation only.
export TF_VERSION="2.21.0"

# ── Networking / distributed ───────────────────────────────────
export OPEN_MPI_VERSION="4.1.8"
export EFA_VERSION="1.48.0"
