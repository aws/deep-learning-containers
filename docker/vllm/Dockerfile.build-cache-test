ARG CUDA_VERSION=12.9.1

# =============================================================================
# STAGE: source — tiny C extension to simulate vLLM compilation
# =============================================================================
FROM nvidia/cuda:${CUDA_VERSION}-devel-amzn2023 AS source

RUN dnf install -y --setopt=install_weak_deps=False \
  python3.12 python3.12-devel python3.12-pip python3.12-setuptools python3.12-wheel gcc \
  && dnf clean all && rm -rf /var/cache/dnf

WORKDIR /src
COPY docker/vllm/build-cache-test/hello.c docker/vllm/build-cache-test/setup.py ./
RUN python3.12 setup.py bdist_wheel --dist-dir=dist

# =============================================================================
# STAGE: build — tests prebuilt wheel + sccache paths
# =============================================================================
FROM nvidia/cuda:${CUDA_VERSION}-devel-amzn2023 AS build

RUN dnf install -y --allowerasing --setopt=install_weak_deps=False \
  python3.12 python3.12-devel python3.12-pip python3.12-setuptools python3.12-wheel \
  gcc curl tar gzip \
  && dnf clean all && rm -rf /var/cache/dnf

WORKDIR /workspace
COPY --from=source /src/hello.c /src/setup.py ./

# --- Pre-built wheel support (same pattern as vLLM Dockerfile) ---
# Fetch wheels into docker/vllm/prebuilt_wheels/ BEFORE docker build.
COPY docker/vllm/prebuilt_wheels/ /tmp/prebuilt_wheels/

# --- sccache support ---
ARG USE_SCCACHE=0

RUN if ls /tmp/prebuilt_wheels/*.whl >/dev/null 2>&1; then \
      echo "PREBUILT WHEEL PATH — skipping compilation" \
      && mkdir -p dist \
      && cp /tmp/prebuilt_wheels/*.whl dist/; \
    elif [ "$USE_SCCACHE" = "1" ]; then \
      echo "SCCACHE PATH — verifying sccache install" \
      && curl -L -o /tmp/sccache.tar.gz \
        "https://github.com/mozilla/sccache/releases/download/v0.8.1/sccache-v0.8.1-x86_64-unknown-linux-musl.tar.gz" \
      && tar -xzf /tmp/sccache.tar.gz -C /tmp \
      && mv /tmp/sccache-v0.8.1-x86_64-unknown-linux-musl/sccache /usr/bin/sccache \
      && rm -rf /tmp/sccache* \
      && sccache --version \
      && echo "sccache installed successfully" \
      && python3.12 setup.py bdist_wheel --dist-dir=dist; \
    else \
      echo "DEFAULT PATH — building from source" \
      && python3.12 setup.py bdist_wheel --dist-dir=dist; \
    fi

# =============================================================================
# STAGE: runtime — install and verify
# =============================================================================
FROM nvidia/cuda:${CUDA_VERSION}-runtime-amzn2023 AS runtime

RUN dnf install -y --setopt=install_weak_deps=False python3.12 python3.12-pip \
  && dnf clean all && rm -rf /var/cache/dnf

COPY --from=build /workspace/dist /tmp/dist
RUN python3.12 -m pip install /tmp/dist/*.whl
RUN python3.12 -c "import hello_ext; print(hello_ext.hello())"
